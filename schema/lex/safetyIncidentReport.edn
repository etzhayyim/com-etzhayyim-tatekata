{:lexicon 1
 :id "com.etzhayyim.tatekata.safetyIncidentReport"
 :description "On-site safety incident report."
 :defs {:main {:type :record
               :record {:type :object
                        :properties {:projectId {:type :string} :incidentDate {:type :string}
                                     :reportDate {:type :string} :incidentType {:type :string}
                                     :severity {:type :string} :description {:type :string}
                                     :rootCause {:type :string}
                                     :correctiveActions {:type :array :items {:type :string}}
                                     :escalation {:type :string}}
                        :required ["projectId" "incidentDate" "reportDate" "incidentType"
                                   "severity" "description"]}}}}
