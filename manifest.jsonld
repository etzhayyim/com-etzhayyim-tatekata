  "id": "did:web:etzhayyim.com:tatekata",
  "name": "tatekata",
  "displayName": "建方 — Construction",
  "displayNameJa": "建方",
  "displayNameEn": "Tatekata",
  "description": "Infrastructure construction robotics orchestration. Tier-B actor coordinating multi-robot site workflows (Giemon, Otete, Mimi), material routing, permit compliance, and safety governance for civil + MEP projects (≤2 story, ≤5000m² R0 scope).",
  "descriptionJa": "インフラ建設ロボティクス・オーケストレーション。複数ロボット(ギエモン、オテテ、ミミ)による施工現場ワークフロー、材料ルーティング、許可申請準拠、安全ガバナンスを統合する。",
  "adr": {
    "master": "etzhayyim:adr:2605250715",
    "r0": "etzhayyim:adr:2605250715",
    "r1": "etzhayyim:adr:2605250730",
    "r2": "etzhayyim:adr:2605250745",
    "r3": "etzhayyim:adr:2605250760"
  },
  "tier": "Tier-B",
  "parentActor": "did:web:etzhayyim.com:kuni-umi",
  "scope": {
    "phase": "R0 scaffold",
    "scopeBoundary": "Infrastructure (civil + MEP)",
    "exclusions": [
      "residential housing",
      "high-rise (>12 stories)",
      "nuclear",
      "hazmat manufacture",
      "architectural design (execution-only actor)",
      "cost estimation (capital domain)"
    ]
  },
  "roboticsClasses": [
    "Giemon (kuni-umi inherited)",
    "Otete (kuni-umi inherited)",
    "Mimi (kuni-umi inherited)",
    "Hitogata (R2+)"
  ],
