  ],
  "constitutionalGates": {
    "description": "14 immutable gates per ADR-2605250700. Changes require Council Lv6+ supermajority + new ADR.",
    "gates": {
      "G1": "All robotics firmware open-source (WASM or Rust crates, Apache 2.0)",
      "G2": "Site photos + depth maps IPFS-pinned before human equipment entry",
      "G3": "≥2 distinct robot signers per progress record (Ed25519, DID-bound)",
      "G4": "All permit PDFs (土地利用計画, 建築許可, 労働安全) English + JA bilingual approved scans",
      "G5": "Material sourcing Charter Rider §2(g) compliant (no conflict minerals, no rare-earth R0)",
      "G6": "Giemon arm trajectory deterministic + re-playable (joint angles logged @ 10 Hz, WASM state-machine sealed)",
      "G7": "No on-site chemical processes (spray foam, epoxy, solvent curing) in R0",
      "G8": "Site DEM + CAD .dwg sourced from vendor-free tools (Open CASCADE, FreeCAD, OpenSCAD)",
      "G9": "Murakumo mesh placement declared 30 days prior, public feedback period",
      "G10": "All subcontractor drones + robots pre-registered in TatekataRoboticsRegistry + background-checked operator DID",
      "G11": "Accident rate ≤ sector baseline × 0.5 (per OSHA). Waive to R1+ via Council vote",
      "G12": "Energy consumption ≤ 150 kWh per 100m³ excavation (giemon + lighting). Exceed = halt + review",
      "G13": "Completion schedule public calendar on IPFS. Reschedule >14d = community comment period",
      "G14": "Final project metadata (projectClosure record) includes material waste log (% reused / recycled / landfill). Charter Rider §2(h) assessment"
    }
  },
  "nonGoals": {
    "description": "10 explicitly excluded scopes (deferred or forbidden)",
    "goals": {
      "N1": "High-rise (>12 stories) construction — complexity + structural dynamics > scope. ADR post-R3 (Level-4 gate)",
      "N2": "Residential housing (R occupancy, Article 7 Building Code) — implies MiyadaikuHousingActor separate gate. ADR separate",
      "N3": "Nuclear site prep / hazmat decontamination — radiological training + sealed facility. Never (constitutional carve-out)",
      "N4": "Chemical manufacturing plant construction — overlap with kuni-umi-S6 chemistry. Never (carve-out to kuni-umi)",
      "N5": "Tunnel / deep underground (>30m depth) — different robotics class (boring machines). ADR post-R3",
      "N6": "Bridge main-span (>500m unsupported) — cable-stayed / suspension specialist. ADR post-R3",
      "N7": "Seismic retrofitting of historical buildings — preservation specialist actor. ADR separate (cultural heritage gate)",
      "N8": "Deep-sea platform construction — marine robotics (Funamori class). Never (scope = onshore / near-shore ≤100m depth)",
      "N9": "Architectural design (aesthetics, style, master planning) — design ≠ construction. Never (design = external input, execution only)",
      "N10": "Cost estimation / budgeting (CNY/USD/JPY forecasting) — finance domain (capital:*). Never (physical execution only)"
    }
  },
  "roadmap": [
    {
      "phase": "R0",
      "date": "2026-05-25",
      "scope": "Scaffold only. No live construction. 5 cells import-time RuntimeError.",
