      "murukumoFleet": "naphtali node (earth-moving)",
      "gate": "ADR-2605250715 (SME civil engineer onboarded + Giemon PoC)"
    },
    {
      "phase": "R2",
      "date": "post-R1",
      "scope": "Pilot site (≤100m², ≤2 story, prefab assembly). Giemon + Otete + manual subcontractors. Incident <baseline. Waste logged. Hitogata mock.",
      "murukumoFleet": "naphtali + joseph + zebulun (3 nodes)",
      "gate": "ADR-2605250730 (30-day public comment + Annex-1 facility parallel, pharma parity)"
    },
    {
      "phase": "R3",
      "date": "post-R2",
      "scope": "Community scale (≤5000m², multi-building campus, open-source permits). Hitogata integration. 60-day public review.",
      "murukumoFleet": "Full 10-node fleet",
      "gate": "ADR-2605250745 (Council multi-domain vote: silicon + pharma + tatekata)"
    }
  ],
